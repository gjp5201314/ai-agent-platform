# ╔══════════════════════════════════════════════════════════════════╗
# ║  TEMPLATE FILE — safe to commit. No real credentials here.     ║
# ║  Copy to backend/.env and fill in your own API keys.           ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# ===== Environment Variables for AI Agent Platform =====

# ---- LLM Configuration ----
# Default provider: qwen | openai | claude
LLM_PROVIDER=qwen

# Qwen (DashScope - OpenAI compatible, recommended for China)
# Get key: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-qwen-dashscope-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# OpenAI (uncomment to use)
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Claude / Anthropic (uncomment to use)
# ANTHROPIC_API_KEY=sk-ant-your-claude-key
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Embedding model (DashScope text-embedding-v3)
EMBEDDING_API_KEY=sk-your-qwen-api-key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1024

# ---- Database (must match docker-compose) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=agent
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=aiagent
DATABASE_URL=postgresql+asyncpg://agent:changeme_strong_password@postgres:5432/aiagent

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
# 密码必须与 docker-compose.yml 中 ${REDIS_PASSWORD} 一致
# 留空时 docker-compose 会用默认值 redis_secure_password
REDIS_PASSWORD=redis_secure_password
REDIS_DB=0

# ---- LangSmith Tracing ----
# Set to true to enable trace logging to LangSmith
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_your_langsmith_key
LANGSMITH_PROJECT=ai-agent-platform

# ---- App ----
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
CORS_ORIGINS=http://localhost,http://localhost:3000

# ---- Mock 模式 ----
# 启用后所有 LLM 调用返回模拟响应，无需 API Key
# 设置为 true 开启全局 Mock，也可通过前台 UI 开关切换
MOCK_MODE_ENABLED=false

# ---- Alibaba Cloud Container Registry (ACR) ----
# 用于生产环境镜像推送/拉取。免费个人版即可。
# 控制台: https://cr.console.aliyun.com/
# 登录密码: 阿里云 RAM 访问控制 → 设置固定密码
# 格式: 注册域名/命名空间
# 示例: ACR_REGISTRY=crpi-xxx.cn-hangzhou.personal.cr.aliyuncs.com/ai_agent_platform
ACR_REGISTRY=crpi-xxx.cn-hangzhou.personal.cr.aliyuncs.com/YOUR_NAMESPACE
ACR_USERNAME=YOUR_ACR_USERNAME
ACR_PASSWORD=YOUR_ACR_PASSWORD
