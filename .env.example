# ===== Environment Variables for AI Agent Platform =====
# Copy this file to backend/.env and fill in your API keys.
# All settings here are for the backend container.

# ---- LLM Configuration ----
# Default provider: qwen | openai | claude
LLM_PROVIDER=qwen

# Qwen (DashScope - OpenAI compatible, recommended for China)
# Get key: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-71364233b04d4e4fb7ff11db3b8994f9
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# OpenAI (uncomment to use)
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Claude / Anthropic (uncomment to use)
# ANTHROPIC_API_KEY=sk-ant-your-claude-key
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Embedding model (DashScope text-embedding-v3)
EMBEDDING_API_KEY=sk-your-qwen-api-key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1024

# ---- Database (must match docker-compose) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=agent
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=aiagent
DATABASE_URL=postgresql+asyncpg://agent:changeme_strong_password@postgres:5432/aiagent

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- LangSmith Tracing ----
# Set to true to enable trace logging to LangSmith
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_your_langsmith_key
LANGSMITH_PROJECT=ai-agent-platform

# ---- App ----
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
CORS_ORIGINS=http://localhost,http://localhost:3000
